# OpenSalesTax engine
OST_ENGINE_URL=http://10.0.0.5:8080
# OST_API_KEY=

# QuickBooks Online OAuth (Intuit Developer Portal -> your app -> Keys & OAuth)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8181/oauth/callback
# 'sandbox' for the Intuit sandbox company; 'production' for real merchants
QBO_ENVIRONMENT=sandbox

# QBO webhook verifier token (Intuit Developer Portal -> Webhooks tab)
QBO_WEBHOOK_VERIFIER_TOKEN=

# Token store path (encrypted; default: ./var/qbo-tokens.json)
# QBO_TOKEN_STORE_PATH=./var/qbo-tokens.json

# Encryption key for at-rest OAuth tokens. 32 bytes base64-encoded.
# Generate with: php -r "echo base64_encode(random_bytes(32)), \"\\n\";"
QBO_TOKEN_ENCRYPTION_KEY=

# Optional knobs
# OST_TIMEOUT_SECONDS=10
# SIDECAR_ALLOW_PRIVATE_NETWORKS=1
# SIDECAR_TLS_VERIFY=1
# SIDECAR_RATE_LIMIT_PER_MINUTE=120
# SIDECAR_REPLAY_WINDOW_SECONDS=300

# Fail-hard mode: webhook 500 on engine error rather than fail-soft (no-op).
# Default OFF (fail-soft). Set to "1" to enable.
# OSTAX_FAIL_HARD=0
