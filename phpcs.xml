<?xml version="1.0"?>
<ruleset name="opensalestax-quickbooks-online">
    <description>PSR-12 coding standard for the OpenSalesTax QuickBooks Online sidecar</description>

    <rule ref="PSR12"/>

    <file>src</file>
    <file>tests</file>
    <file>bin</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*\.xml$</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="p"/>
</ruleset>
